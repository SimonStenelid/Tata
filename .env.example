DATABASE_URL="file:./dev.db"

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user ids that may talk to the bot.
# Find yours by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=

# Optional: override the SQLite path the agent reads/writes.
# AGENT_DB_PATH=./dev.db

# Optional: override the labels written into Transaction.source for each upload keyword.
# Defaults: SOURCE_DEBIT_LABEL=Handelsbanken, SOURCE_AMEX_LABEL=Amex
# SOURCE_DEBIT_LABEL=Handelsbanken
# SOURCE_AMEX_LABEL=Amex
